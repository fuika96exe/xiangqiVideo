                                                    "moves": [
                                                        {
                                                            "uci": "h1h9",
                                                            "note": "防止黑马8+7跳马，暂时一车压车马两子。",
                                                            "moves": [
                                                                {
                                                                    "uci": "d10e9",
                                                                    "note": "补士后可包2-1赶走红恶车。",
                                                                    "moves": [
                                                                        {
